# =============================================================================
# Finbrain Backend — Environment Variables
# Location: backend/.env.example
#
# Copy to your shell, Render dashboard, or GitHub Secrets.
# NEVER commit real values to version control.
# =============================================================================

# --- Core ---
SPRING_PROFILES_ACTIVE=dev
PORT=8081

# --- Database (production — PostgreSQL on Render) ---
# Render auto-populates DATABASE_* when PostgreSQL is linked via render.yaml
DATABASE_HOST=your-db-host.render.com
DATABASE_PORT=5432
DATABASE_NAME=finbrain
DATABASE_USER=finbrain
DATABASE_PASSWORD=your-database-password

# Alternative: full JDBC URL (overrides DATABASE_* composition)
SPRING_DATASOURCE_URL=jdbc:postgresql://your-db-host.render.com:5432/finbrain
SPRING_DATASOURCE_USERNAME=finbrain
SPRING_DATASOURCE_PASSWORD=your-database-password

# Render internal connection string (postgres:// format — NOT used directly by Spring)
# Convert to JDBC or use DATABASE_* vars above
DATABASE_URL=postgresql://user:password@host:5432/finbrain

# --- Security ---
# Generate with: openssl rand -base64 64
JWT_SECRET=your-long-random-jwt-secret-minimum-32-characters
JWT_EXPIRATION_MS=86400000

# --- CORS / Frontend ---
FRONTEND_URL=https://your-app.vercel.app
CORS_ALLOWED_ORIGINS=https://your-app.vercel.app

# --- JVM (Docker / Render) ---
JAVA_OPTS=-XX:+UseContainerSupport -XX:MaxRAMPercentage=75.0

# --- Connection pool (optional) ---
DB_POOL_MAX_SIZE=10
DB_POOL_MIN_IDLE=2

# --- Development only (H2 — dev profile) ---
DB_USERNAME=sa
DB_PASSWORD=

# --- Mail (optional — not used by current codebase) ---
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=your-email@example.com
MAIL_PASSWORD=your-email-app-password

# --- Cloudinary (optional — not used by current codebase) ---
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# --- Third-party API keys (optional — add as needed) ---
# OPENAI_API_KEY=your-openai-key
