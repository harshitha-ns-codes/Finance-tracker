# =============================================================================
# Finbrain Backend — Environment Variables
# Location: backend/.env.example
#
# Production (Render + Neon): set in Render dashboard
# Development: export locally or use defaults in application-dev.properties
# =============================================================================

# --- Core ---
SPRING_PROFILES_ACTIVE=dev
PORT=8081

# --- Database (production — Neon PostgreSQL on Render) ---
# From Neon dashboard → Connection Details → JDBC
# Must include sslmode=require for Neon
DATABASE_URL=jdbc:postgresql://<host>:5432/neondb?sslmode=require
DATABASE_USERNAME=your-neon-username
DATABASE_PASSWORD=your-neon-password

# --- Security ---
# Generate with: openssl rand -base64 64
JWT_SECRET=your-long-random-jwt-secret-minimum-32-characters

# --- CORS / Frontend (Vite local + Vercel) ---
# Vite local ports are always allowed in code (localhost:5173 / 5174).
# For production: set these in the RENDER dashboard (Environment), not only here.
# Paste your current Vercel URL below (no trailing slash):
#   https://YOUR-NEW-APP-NAME.vercel.app
FRONTEND_URL=https://YOUR-APP.vercel.app
CORS_ALLOWED_ORIGINS=https://YOUR-APP.vercel.app

# --- Development only (H2 — dev profile) ---
DB_USERNAME=sa
DB_PASSWORD=
