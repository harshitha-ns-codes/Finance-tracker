# =============================================================================
# Finbrain Frontend — Environment Variables
# Location: frontend/.env.example
#
# Copy to frontend/.env.local for local development.
# Set in Vercel dashboard for production.
# Only VITE_* variables are exposed to the browser — never put secrets here.
# =============================================================================

# Backend API base URL (include /api suffix, no trailing slash)
# Local dev: use /api (Vite proxy forwards to localhost:8081)
VITE_API_BASE_URL=/api

# Vercel production (recommended — uses vercel.json proxy to Render, avoids CORS):
VITE_API_BASE_URL=/api

# Direct to Render (optional — also set CORS on Render):
# VITE_API_BASE_URL=https://finbrain-64cw.onrender.com/api

# Application display name (public)
VITE_APP_NAME=Finbrain

# Dev proxy target (vite.config.mts only — not exposed to browser)
VITE_DEV_PROXY_TARGET=http://localhost:8081

# Public third-party keys (optional — add only if integrated)
# VITE_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
# VITE_SENTRY_DSN=https://example@sentry.io/project
